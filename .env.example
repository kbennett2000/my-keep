# Copy this file to .env and adjust as needed:  cp .env.example .env

# Port the server listens on. Change this one value to run on a different port.
PORT=8065

# Secret used to sign session cookies. Set this to a long random string.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Where the SQLite database and uploaded images are stored.
# Relative paths resolve against the project root.
DATA_DIR=./data
