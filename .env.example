# Copy this file to .env and adjust as needed:  cp .env.example .env

# The port you'll open MyKeep on. Change this one value to use a different port.
PORT=8065

# Secret used to sign login cookies. Set this to a long random string.
# Generate one with either of these (pick whichever you have):
#   openssl rand -hex 32
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Where the notes database and uploaded images are stored.
# Running with Docker (the normal way): leave this alone — data is stored in the
#   ./data folder next to docker-compose.yml, and the container path is fixed.
# Running directly with Node instead: this path resolves against the project root.
DATA_DIR=./data
