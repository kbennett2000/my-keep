{
  "name": "my-keep",
  "version": "0.1.0",
  "description": "MyKeep — a self-hosted, fully-offline Google Keep clone for home-LAN use.",
  "private": true,
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "test": "node --test --test-force-exit \"test/**/*.test.js\"",
    "audit:offline": "bash scripts/offline-audit.sh",
    "screenshots": "node scripts/screenshots.mjs"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.8.1",
    "better-sqlite3-session-store": "^0.1.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "playwright": "^1.60.0",
    "supertest": "^7.0.0"
  }
}
